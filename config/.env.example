# -----------------------------------------------------------------------------
# GLPI Operations Kit - Public Product Configuration Template
# -----------------------------------------------------------------------------
# Copy this file and rename it to your environment before running scripts.
# Example:
#   cp config/.env.example config/staging.env
#   cp config/.env.example config/production.env
#
# This file stores deployment values consumed by scripts, including required secrets.
# Protect environment-specific copies (`config/<environment>.env`) with strict file permissions.
# Convention:
# - keep only mandatory baseline keys uncommented in this template;
# - optional keys stay commented and must be explicitly uncommented/configured when needed.
# -----------------------------------------------------------------------------

# Product display name shown in reports and runtime metadata.
# Format: string
# Example: GLPI Operations Kit
PRODUCT_NAME=GLPI Operations Kit

# Stable product slug for labels and automation.
# Format: lowercase string with hyphen
# Example: glpi-operations-kit
#PRODUCT_SLUG=glpi-operations-kit

# Deployment label for this package instance.
# Format: string
# Example: reference-kit
#PRODUCT_DEPLOYMENT_LABEL=reference-kit

# Customer-facing name used in labels and dashboards.
# Format: string
# Example: Example Customer
CUSTOMER_DISPLAY_NAME=Example Customer

# Short customer identifier used in tags.
# Format: lowercase string with hyphen
# Example: example-customer
#CUSTOMER_SHORT_NAME=example-customer

# Logical environment name consumed by scripts and reports.
# Format: string (letters, numbers, . _ -)
# Example: staging
ENVIRONMENT_NAME=example

# Human-readable environment stage used in labels.
# Format: string
# Example: staging
#ENVIRONMENT_STAGE=staging

# Execution mode for orchestration.
# Format: local|ssh
# local = run on current host only (recommended when SSH between servers is blocked)
# ssh   = run remotely from one host to others
#EXECUTION_MODE=local

# Default host role for local mode.
# Format: app|db|all
# app = app-only actions, db = db-only actions, all = both (single-host flow)
#EXECUTION_HOST_ROLE_DEFAULT=all

# Target topology.
# Format: single-server|dual-server
#TOPOLOGY_MODE=dual-server

# Inventory alias for application host.
# Format: short string
TOPOLOGY_APP_ALIAS=app-node

# Application host endpoint.
# Format: IPv4, IPv6, or FQDN
TOPOLOGY_APP_HOST=192.0.2.10

# Inventory alias for database host.
# Format: short string
TOPOLOGY_DB_ALIAS=db-node

# Database host endpoint.
# Format: IPv4, IPv6, or FQDN
TOPOLOGY_DB_HOST=192.0.2.20

# SSH username used only when EXECUTION_MODE=ssh.
# Format: Linux username
#NETWORK_SSH_USER=ubuntu

# SSH private key used only when EXECUTION_MODE=ssh.
# Format: path
# Recommendation: one key pair per environment, private key mode 0600
#NETWORK_SSH_PRIVATE_KEY_PATH=~/.ssh/glpi_example_ed25519

# App host allowed to connect to MariaDB (grant scope).
# Format: IPv4, IPv6, or FQDN
# Example: 192.0.2.10
NETWORK_DATABASE_APP_ACCESS_HOST=192.0.2.10

# Database network access mode.
# Format: restricted|open
# restricted: only explicit sources are allowed.
# open: no source restriction (firewall and DB grant accept any origin).
NETWORK_DATABASE_ACCESS_MODE=restricted
#NETWORK_DATABASE_ACCESS_MODE=open

# CSV allowlist for DB access firewall/grants.
# Format: comma-separated hosts
# restricted mode: use a comma-separated host list
# Example restricted active value: NETWORK_DATABASE_ALLOWED_SOURCE_HOSTS=192.0.2.10,192.0.2.11
# open mode: keep this key active and empty
# Example open active value: NETWORK_DATABASE_ALLOWED_SOURCE_HOSTS=
# Example restricted value kept commented when not used:
#NETWORK_DATABASE_ALLOWED_SOURCE_HOSTS=192.0.2.10,192.0.2.11
NETWORK_DATABASE_ALLOWED_SOURCE_HOSTS=192.0.2.10

# GLPI target version.
# Format: semantic version
GLPI_VERSION=11.0.0

# GLPI endpoint domain or hostname.
# Format: FQDN or hostname
GLPI_DOMAIN=glpi.example.internal

# GLPI installation mode.
# Format: cli|wizard|defer
# cli    = deploy config_db.php and run automated schema bootstrap when needed.
# wizard = prepare app/web/PHP/paths only; do not create config_db.php or run db:install.
# defer  = technical schema deferral; use wizard for manual browser installation.
#GLPI_INSTALLATION_MODE=cli

# Allow wizard mode to move an existing config_db.php to a timestamped backup.
# Format: true|false
# Default: false. Only intended for fresh non-production installs with an empty GLPI schema.
#GLPI_WIZARD_RESET_CONFIG_DB=false

# Web server type supported by GLPI.
# Format: nginx|apache|lighttpd
WEB_SERVER_TYPE=nginx

# PHP upload max size.
# Format: PHP size syntax
#GLPI_UPLOAD_MAX_FILESIZE=32M

# PHP post max size.
# Format: PHP size syntax
#GLPI_POST_MAX_SIZE=32M

# PHP memory limit.
# Format: PHP size syntax
#GLPI_MEMORY_LIMIT=512M

# PHP max execution time in seconds.
# Format: integer
#GLPI_MAX_EXECUTION_TIME=120

# PHP OPcache memory consumption in MB.
# Format: integer
#GLPI_OPCACHE_MEMORY_CONSUMPTION=192

# GLPI cron schedule.
# Format: cron expression (quote required because of spaces)
#GLPI_CRON_SCHEDULE="*/5 * * * *"

# Owner of writable GLPI runtime paths.
# Format: Linux user
# Default by platform: Ubuntu/Debian=www-data, Rocky/RHEL-like=apache
#GLPI_FILESYSTEM_OWNER=www-data

# Group of writable GLPI runtime paths.
# Format: Linux group
# Default by platform: Ubuntu/Debian=www-data, Rocky/RHEL-like=apache
#GLPI_FILESYSTEM_GROUP=www-data

# Application packages (CSV).
# Format: comma-separated package names
# Leave empty to use automatic package set based on WEB_SERVER_TYPE.
# Automatic source: scripts/lib/render_product_config.py
# It combines platform-specific WEB_SERVER_PACKAGES[WEB_SERVER_TYPE] + DEFAULT_GLPI_APP_PACKAGES.
# Rocky/RHEL-like automatically adds mod_ssl only for WEB_SERVER_TYPE=apache with TLS_MODE!=none.
# A manual override must contain every mandatory package for the selected engine/TLS mode or validation fails.
# Ubuntu/Debian baseline includes mariadb-client; Rocky/RHEL-like baseline includes mariadb.
# The default baseline includes php-bcmath (GLPI 11), Redis, and a MariaDB client for APP->DB checks.
# If you set GLPI_APP_PACKAGES manually, it becomes a full override.
#GLPI_APP_PACKAGES=

# Redis cache prefix for GLPI cache namespace.
# Format: string
# Empty/commented uses glpi_cache_<hostname>: on the target host.
#GLPI_REDIS_CACHE_PREFIX=

# Redis session locking for PHP sessions.
# Format: 0|1
# Default 0 avoids phpredis session locking for concurrent GLPI AJAX requests.
#GLPI_REDIS_SESSION_LOCKING=0

# Optional Redis maxmemory. Leave commented to avoid host-size tuning.
# Format: Redis size, for example 512mb or 2gb
#GLPI_REDIS_MAXMEMORY=

# Optional Redis maxmemory policy. Leave commented unless maxmemory is sized.
# Format: Redis maxmemory-policy value
#GLPI_REDIS_MAXMEMORY_POLICY=

# GLPI database schema name.
# Format: SQL identifier
DATABASE_NAME=glpi_operational

# GLPI database username.
# Format: SQL identifier
# Recommendation: use contextual naming, avoid common generic names
DATABASE_USER=nehemiah_glpi

# GLPI database password.
# Format: strong secret string
DATABASE_PASSWORD=

# Managed DB fallback admin password used only for connectivity validation attempts.
# Format: strong secret string
# Optional. Used when DATABASE_DEPLOYMENT_MODE=managed for fallback users root/admin.
DATABASE_MANAGED_ADMIN_PASSWORD=

# Database deployment mode.
# Format: self_hosted|managed
# self_hosted = DB runs on Linux host managed by this kit (MariaDB role, grants, local exporter).
# managed     = DB is external managed service (for example AWS RDS), accessed over TCP only.
# Default behavior when omitted: self_hosted
#DATABASE_DEPLOYMENT_MODE=self_hosted

# Database compatibility policy.
# Format: block|warn|defer
# block = fail when DB is incompatible with selected GLPI version.
# warn  = warn and allow continuing after explicit confirmation.
# defer = allow app deployment but skip DB schema/bootstrap/web checks until DB is upgraded.
# Default: block
# Use warn/defer only in non-production environments with explicit justification.
#DATABASE_COMPATIBILITY_POLICY=block

# Required when DATABASE_COMPATIBILITY_POLICY is warn or defer.
# Format: short operational justification without secrets.
#DATABASE_COMPATIBILITY_JUSTIFICATION=

# Require an interactive operator confirmation for warn/defer.
# Format: true|false
#DATABASE_COMPATIBILITY_REQUIRE_INTERACTIVE_CONFIRMATION=true

# Non-interactive confirmation for CI/automation. Keep false by default.
# Format: true|false
#DATABASE_COMPATIBILITY_ASSUME_YES=false

# Emergency production override for unsupported DB continuation. Keep false by default.
# Format: true|false
#DATABASE_UNSUPPORTED_PROD_OVERRIDE=false

# MariaDB root password for provisioning and maintenance.
# Format: strong secret string
# Required when DATABASE_DEPLOYMENT_MODE=self_hosted.
DATABASE_ROOT_PASSWORD=

# MariaDB TCP port.
# Format: integer
#DATABASE_PORT=3306

# MariaDB bind address.
# Format: IPv4, IPv6, or 0.0.0.0
#DATABASE_BIND_ADDRESS=0.0.0.0

# Database package list (CSV).
# Format: comma-separated package names
# Default by platform: Ubuntu/Debian=mariadb-server,mariadb-client,python3-pymysql; Rocky/RHEL-like=mariadb-server,mariadb,python3-PyMySQL
#DATABASE_PACKAGES=mariadb-server,mariadb-client,python3-pymysql

# PHP-FPM service name.
# Format: systemd unit name without suffix
# Default by platform: Ubuntu/Debian=php8.3-fpm, Rocky/RHEL-like=php-fpm
#PHP_FPM_SERVICE_NAME=php8.3-fpm

# PHP-FPM socket path.
# Format: absolute path
# Default by platform: Ubuntu/Debian=/run/php/php8.3-fpm.sock, Rocky/RHEL-like=/run/php-fpm/glpi.sock
#PHP_FPM_SOCKET=/run/php/php8.3-fpm.sock

# PHP-FPM process manager.
# Format: static|dynamic|ondemand
#PHP_FPM_PM=dynamic

# Web HTTP port.
# Format: integer
WEB_HTTP_PORT=80

# Web HTTPS port.
# Format: integer
WEB_HTTPS_PORT=443

# TLS mode.
# Format: none|self_signed|provided
# none        = HTTP only
# self_signed = script generates local self-signed cert
# provided    = install certificate and key provided by operator
TLS_MODE=none

# TLS common name used for certificate validation/self-signed generation.
# Format: FQDN
# When omitted or empty, GLPI_DOMAIN is used. Self-signed SANs are derived from
# TLS_COMMON_NAME and GLPI_DOMAIN; no IP SAN is added automatically.
#TLS_COMMON_NAME=glpi.example.internal

# Certificate path on target app host.
# Format: absolute path
#TLS_CERTIFICATE_PATH=/etc/ssl/certs/glpi-example.crt

# Private key path on target app host.
# Format: absolute path
#TLS_PRIVATE_KEY_PATH=/etc/ssl/private/glpi-example.key

# Local certificate source path used by install-provided workflow.
# Format: absolute or home-relative path
#TLS_PROVIDED_LOCAL_CERT_PATH=

# Local private key source path used by install-provided workflow.
# Format: absolute or home-relative path
#TLS_PROVIDED_LOCAL_KEY_PATH=

# Backup base directory on target host.
# Format: absolute path
#BACKUP_BASE_DIR=/var/backups/glpi

# Backup retention in days.
# Format: integer
#BACKUP_RETENTION_DAYS=14

# Monitoring deployment profile.
# Format: minimal|standard|full|external_prometheus|external_grafana
# Default minimal deploys node_exporter and blackbox_exporter only.
#MONITORING_PROFILE=minimal

# Enable local Prometheus deployment.
# Format: true|false
#MONITORING_PROMETHEUS_ENABLED=false

# Prometheus internal bind address.
# Format: IPv4, IPv6, or hostname
#MONITORING_PROMETHEUS_BIND_HOST=127.0.0.1

# Prometheus internal port.
# Format: integer
#MONITORING_PROMETHEUS_PORT=9090

# Prometheus local retention time.
# Format: Prometheus duration
#MONITORING_PROMETHEUS_RETENTION_TIME=15d

# Prometheus local retention size.
# Format: Prometheus size
#MONITORING_PROMETHEUS_RETENTION_SIZE=4GB

# Enable local Grafana deployment.
# Format: true|false
#MONITORING_GRAFANA_ENABLED=false

# Grafana administrator username.
# Format: Linux/application identifier
#MONITORING_GRAFANA_ADMIN_USER=daniel_monitor

# Grafana internal bind address.
# Format: IPv4, IPv6, or hostname
#MONITORING_GRAFANA_BIND_HOST=127.0.0.1

# Grafana internal port.
# Format: integer
#MONITORING_GRAFANA_PORT=3000

# Grafana external publication mode.
# Format: disabled|path|subdomain
#MONITORING_GRAFANA_PUBLIC_MODE=disabled

# Grafana public path when publication mode is path.
# Format: absolute URL path
#MONITORING_GRAFANA_PUBLIC_PATH=/monitoring/

# Grafana public FQDN when publication mode is subdomain.
# Format: FQDN
#MONITORING_GRAFANA_PUBLIC_FQDN=

# Legacy alias for Grafana public FQDN. Prefer MONITORING_GRAFANA_PUBLIC_FQDN.
# Format: FQDN
#MONITORING_GRAFANA_DOMAIN=

# Require authentication for externally published Grafana.
# Format: true|false
#MONITORING_GRAFANA_REQUIRE_AUTH=true

# Require HTTPS for externally published Grafana.
# Format: true|false
#MONITORING_GRAFANA_REQUIRE_HTTPS=true

# Default exporter bind address. Exporters must stay internal.
# Format: IPv4, IPv6, or hostname
#MONITORING_EXPORTER_BIND_HOST=127.0.0.1

# Source hosts allowed to scrape exporters when bind address is not loopback.
# Format: CSV
#MONITORING_EXPORTER_ALLOWED_SOURCE_HOSTS=

# Enable Node Exporter deployment.
# Format: true|false
#MONITORING_NODE_EXPORTER_ENABLED=true

# Enable mysqld_exporter deployment.
# Format: true|false
#MONITORING_MYSQLD_EXPORTER_ENABLED=false

# mysqld_exporter username.
# Format: SQL identifier
MONITORING_MYSQLD_EXPORTER_USER=issachar_monitor

# mysqld_exporter password is a runtime secret.
# Secret key: mysqld_exporter_password in .runtime/<environment>/secrets.yml

# Enable Nginx exporter deployment.
# Format: true|false
#MONITORING_NGINX_EXPORTER_ENABLED=false

# Enable PHP-FPM exporter deployment.
# Format: true|false
#MONITORING_PHP_FPM_EXPORTER_ENABLED=false

# Enable Blackbox exporter deployment.
# Format: true|false
#MONITORING_BLACKBOX_EXPORTER_ENABLED=true

# Blackbox probe targets controlled by product config.
# Format: JSON array of HTTP/HTTPS URLs
#MONITORING_BLACKBOX_TARGETS_JSON=["https://glpi.example.internal/"]

# Enable GLPI functional metrics through node_exporter textfile collector.
# Format: true|false
#MONITORING_GLPI_CUSTOM_METRICS_ENABLED=false

# GLPI functional metrics collection interval.
# Format: integer seconds
#MONITORING_GLPI_CUSTOM_METRICS_INTERVAL_SECONDS=300

# GLPI metrics database username.
# Format: SQL identifier
#MONITORING_GLPI_METRICS_DB_USER=amos_metrics

# Enable backup freshness metrics.
# Format: true|false
#MONITORING_GLPI_BACKUP_FRESHNESS_ENABLED=false

# Maximum acceptable age for last successful GLPI backup.
# Format: integer hours
#MONITORING_GLPI_BACKUP_MAX_AGE_HOURS=24

# Monitoring labels as JSON object.
# Format: JSON object in one line
#MONITORING_LABELS_JSON={"product":"glpi","service":"itsm","customer":"example-customer","environment":"example"}

# Monitoring threshold catalog as JSON object.
# Format: JSON object in one line
#MONITORING_THRESHOLDS_JSON={"cpu_warning_percent":80,"cpu_critical_percent":90,"memory_warning_percent":80,"memory_critical_percent":90,"disk_warning_percent":80,"disk_critical_percent":90,"tls_expiry_warning_days":30}

# Scrape profiles as JSON object.
# Format: JSON object in one line
#MONITORING_SCRAPE_PROFILES_JSON={"default":{"interval":"30s","timeout":"10s"}}

# Dashboard profile label.
# Format: string
#MONITORING_DASHBOARD_PROFILE=glpi-standard

# Alert routing contract as JSON object.
# Format: JSON object in one line
#MONITORING_ALERT_ROUTES_JSON={"default_receiver":"operations-team","escalation_policy":"customer-on-call"}

# Enable Alertmanager deployment. Reserved for a later phase.
# Format: true|false
#ALERTMANAGER_ENABLED=false

# Alertmanager internal bind address. Reserved for a later phase.
# Format: IPv4, IPv6, or hostname
#MONITORING_ALERTMANAGER_BIND_HOST=127.0.0.1

# Alertmanager internal port. Reserved for a later phase.
# Format: integer
#MONITORING_ALERTMANAGER_PORT=9093

# Days before TLS expiration alert.
# Format: integer
#ALERTING_TLS_EXPIRY_WARNING_DAYS=30

# Backup failure alert toggle.
# Format: true|false
#ALERTING_BACKUP_FAILURE_ENABLED=true

# Service down alert toggle.
# Format: true|false
#ALERTING_SERVICE_DOWN_ENABLED=true

# SSO/SAML/OIDC configuration is intentionally manual in the GLPI application.
# This kit does not orchestrate identity provider settings.
# Legacy AUTH_*/SSO_* keys may exist in older environment files and are ignored by execution flows.

# Enable Mailpit post-deploy email capture service.
# Format: true|false
#EMAIL_MAILPIT_ENABLED=false

# Mailpit container image. Pin a version; do not use latest for production.
# Format: repository:tag
#EMAIL_MAILPIT_IMAGE=axllent/mailpit:v1.30.1

# Mailpit UI path exposed through the configured GLPI web protocol/port.
# Format: absolute URL path
#EMAIL_MAILPIT_UI_PATH=/mailpit

# Host bind address for the internal Mailpit UI port.
# Format: IPv4 or hostname
#EMAIL_MAILPIT_UI_BIND_HOST=127.0.0.1

# Internal Mailpit UI port published only on EMAIL_MAILPIT_UI_BIND_HOST.
# Format: integer
#EMAIL_MAILPIT_UI_INTERNAL_PORT=8025

# Host bind address for Mailpit SMTP.
# Format: IPv4 or hostname
#EMAIL_MAILPIT_SMTP_BIND_HOST=127.0.0.1

# Mailpit SMTP port published only on EMAIL_MAILPIT_SMTP_BIND_HOST.
# Format: integer
#EMAIL_MAILPIT_SMTP_PORT=1025

# Maximum messages kept in Mailpit storage.
# Format: integer
#EMAIL_MAILPIT_MAX_MESSAGES=1000

# Flag for allowing insecure modes when accepted by operator policy.
# Format: true|false
#SECURITY_ALLOW_INSECURE_NON_PRODUCTION=true

# Require TLS mode to be provided.
# Format: true|false
#SECURITY_REQUIRE_TLS=false

# Require HTTPS/TLS enabled.
# Format: true|false
#SECURITY_REQUIRE_HTTPS=false

# Require staging certification gate artifact.
# Format: true|false
#SECURITY_REQUIRE_PROMOTION_GATE=false

# Require deploy order check -> db -> app -> monitoring -> backup -> post-check.
# Format: true|false
#SECURITY_REQUIRE_ORDERED_EXECUTION=true

# Confirm DB apply was already completed on another host before running app apply
# in local dual-server mode. This only affects ordered-execution validation.
# Format: true|false
#OPERATIONS_ASSUME_DB_APPLIED=false

# GLPI release extraction root.
# Format: absolute path
#PATH_GLPI_RELEASE_ROOT=/usr/share

# GLPI installation directory.
# Format: absolute path
#PATH_GLPI_INSTALL_DIR=/usr/share/glpi

# GLPI config directory (outside web root).
# Format: absolute path
#PATH_GLPI_CONFIG_DIR=/etc/glpi

# GLPI variable directory (outside web root).
# Format: absolute path
#PATH_GLPI_VAR_DIR=/var/lib/glpi/files

# GLPI plugins directory.
# Format: absolute path
#PATH_GLPI_PLUGIN_DIR=/var/lib/glpi/plugins

# GLPI logs directory.
# Format: absolute path
#PATH_GLPI_LOG_DIR=/var/log/glpi

# System timezone.
# Format: tz database value
OPERATIONS_TIMEZONE=America/Sao_Paulo

# Enable GLPI timezone support checks/workflows.
# Format: true|false
#GLPI_TIMEZONE_SUPPORT_ENABLED=false

# Timezone behavior for DB layer.
# Format: disabled|validate|apply
# disabled = skip DB timezone checks
# validate = check DB timezone readiness only (recommended for managed DB such as AWS RDS)
# apply    = load DB timezone tables when applicable (self-hosted by default; managed only with explicit confirmation)
#GLPI_TIMEZONE_DB_MODE=disabled

# Optional legacy grant for older GLPI workflows.
# Format: true|false
# true  = try to grant SELECT on mysql.time_zone_name to GLPI DB user
# false = do not apply legacy grant (recommended for newer GLPI versions)
#GLPI_TIMEZONE_DB_LEGACY_GRANT=false

# GLPI cron schedule used by application role.
# Format: cron expression (quote required because of spaces)
#OPERATIONS_GLPI_CRON_SCHEDULE="*/5 * * * *"

# Required Linux group for operators.
# Format: Linux group name
#OPERATIONS_REQUIRED_OPS_GROUP=glpiops

# Default security mode when SECURITY_MODE is not passed in command line.
# Format: secure|permissive
#OPERATIONS_SECURITY_MODE_DEFAULT=secure

# Mandatory justification used only when OPERATIONS_SECURITY_MODE_DEFAULT=permissive
# or SECURITY_MODE=permissive is passed at runtime.
# Format: text
#OPERATIONS_PERMISSIVE_JUSTIFICATION=

# Active sizing profile consumed by runtime renderer.
# Format: small|medium|large
RESOURCE_PROFILE_ACTIVE=small

# ------------------------------- SMALL PROFILE -------------------------------
#RESOURCE_PROFILE_SMALL_PHP_MAX_CHILDREN=20
#RESOURCE_PROFILE_SMALL_PHP_START_SERVERS=4
#RESOURCE_PROFILE_SMALL_PHP_MIN_SPARE_SERVERS=2
#RESOURCE_PROFILE_SMALL_PHP_MAX_SPARE_SERVERS=6
#RESOURCE_PROFILE_SMALL_PHP_MAX_REQUESTS=500
#RESOURCE_PROFILE_SMALL_MARIADB_INNODB_BUFFER_POOL_SIZE=2G
#RESOURCE_PROFILE_SMALL_MARIADB_MAX_CONNECTIONS=80
#RESOURCE_PROFILE_SMALL_MARIADB_TMP_TABLE_SIZE=128M
#RESOURCE_PROFILE_SMALL_MARIADB_MAX_HEAP_TABLE_SIZE=128M
#RESOURCE_PROFILE_SMALL_MARIADB_SLOW_QUERY_LOG=1
#RESOURCE_PROFILE_SMALL_MARIADB_LONG_QUERY_TIME=2

# ------------------------------ MEDIUM PROFILE -------------------------------
#RESOURCE_PROFILE_MEDIUM_PHP_MAX_CHILDREN=35
#RESOURCE_PROFILE_MEDIUM_PHP_START_SERVERS=6
#RESOURCE_PROFILE_MEDIUM_PHP_MIN_SPARE_SERVERS=3
#RESOURCE_PROFILE_MEDIUM_PHP_MAX_SPARE_SERVERS=10
#RESOURCE_PROFILE_MEDIUM_PHP_MAX_REQUESTS=500
#RESOURCE_PROFILE_MEDIUM_MARIADB_INNODB_BUFFER_POOL_SIZE=8G
#RESOURCE_PROFILE_MEDIUM_MARIADB_MAX_CONNECTIONS=120
#RESOURCE_PROFILE_MEDIUM_MARIADB_TMP_TABLE_SIZE=192M
#RESOURCE_PROFILE_MEDIUM_MARIADB_MAX_HEAP_TABLE_SIZE=192M
#RESOURCE_PROFILE_MEDIUM_MARIADB_SLOW_QUERY_LOG=1
#RESOURCE_PROFILE_MEDIUM_MARIADB_LONG_QUERY_TIME=2

# ------------------------------- LARGE PROFILE -------------------------------
#RESOURCE_PROFILE_LARGE_PHP_MAX_CHILDREN=50
#RESOURCE_PROFILE_LARGE_PHP_START_SERVERS=8
#RESOURCE_PROFILE_LARGE_PHP_MIN_SPARE_SERVERS=4
#RESOURCE_PROFILE_LARGE_PHP_MAX_SPARE_SERVERS=12
#RESOURCE_PROFILE_LARGE_PHP_MAX_REQUESTS=500
#RESOURCE_PROFILE_LARGE_MARIADB_INNODB_BUFFER_POOL_SIZE=24G
#RESOURCE_PROFILE_LARGE_MARIADB_MAX_CONNECTIONS=180
#RESOURCE_PROFILE_LARGE_MARIADB_TMP_TABLE_SIZE=256M
#RESOURCE_PROFILE_LARGE_MARIADB_MAX_HEAP_TABLE_SIZE=256M
#RESOURCE_PROFILE_LARGE_MARIADB_SLOW_QUERY_LOG=1
#RESOURCE_PROFILE_LARGE_MARIADB_LONG_QUERY_TIME=2
